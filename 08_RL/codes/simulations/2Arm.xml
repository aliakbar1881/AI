<mujoco>
    <compiler angle="degree"/>
    <worldbody>
        <light directional="true" dir="0 -1 -1"/>
        <body name="upper_arm" pos="0 0 0">
            <joint name="your_joint_name" type="hinge" axis="0 1 0"/>
            <geom type="capsule" fromto="0 0 0 1 0 0" size="0.05"/>

            <!-- Lower arm attached below upper arm -->
            <body name="lower_arm" pos="1 0 0">
                <joint type="hinge" axis="0 1 0"/>
                <geom type="capsule" fromto="0 0 0 1 0 0" size="0.05"/>
            </body>
        </body>
        <body name="tip" pos="2 0 0">
            <site name="tip_site"/>
        </body>
    </worldbody>
    <actuator>
        <motor name="arm_motor" joint="your_joint_name" gear="100"/>
    </actuator>
    <sensor>
        <accelerometer name="acc_sensor" site="tip_site"/>
    </sensor>
</mujoco>